  "keyFeatures": [
    "Multi-tenant architecture with isolated vendor environments",
    "Custom vendor subdomains and storefronts",
    "Stripe Connect integration with automatic platform fees",
    "Product ratings and reviews system",
    "User purchase library for digital products",
    "Role-based access control (super-admin, user)",
    "Admin and merchant dashboards",
    "Category and tag-based product filtering",
    "Full-text search functionality",
    "Payload CMS backend with MongoDB",
    "Next.js 15 with App Router",
    "shadcn/ui component library",
    "tRPC type-safe API layer"
  ],
  "publicApiSurface": [
    "auth.session - Get current user session",
    "auth.register - Register new user and create tenant",
    "auth.login - User authentication",
    "products.getOne - Fetch single product by ID",
    "products.getMany - List products with filtering and pagination",
    "tenants.getOne - Get tenant by slug",
    "checkout.getProducts - Get products for checkout by IDs",
    "categories.getMany - List categories with subcategories",
    "tags.getMany - List available tags",
    "Collections: Users, Tenants, Products, Categories, Tags, Media"
  ]
